{
  "name": "modbus-bridge",
  "version": "1.0.0",
  "description": "Local Modbus bridge for Fox ESS inverters (H1, H3, KH, and variants)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run build:telemetry && tsc",
    "build:telemetry": "tsc -p packages/modbus-telemetry/tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "probe": "node dist/probe.js",
    "test": "vitest"
  },
  "dependencies": {
    "@checkmysolar/modbus-telemetry": "file:./packages/modbus-telemetry",
    "better-sqlite3": "^13.0.1",
    "luxon": "^3.7.2",
    "modbus-serial": "^8.0.23"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/luxon": "^3.7.2",
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "better-sqlite3@13.0.1": true
  }
}
